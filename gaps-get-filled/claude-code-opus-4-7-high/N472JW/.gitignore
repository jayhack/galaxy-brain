# This submission ships a small demo dataset (data/cache/*.parquet for 7
# symbols) and a sample run (results/runs/test_7sym/) so the evaluator can
# see a dashboard immediately. Fresh runs the evaluator kicks off land in
# results/runs/<timestamp>/ — ignored so they don't pollute the submission.

# runtime artifacts from fresh runs (timestamped dirs start with "20..")
results/runs/20*/

